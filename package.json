{
  "name": "agent-manager",
  "version": "2.0.0",
  "description": "Universal CLI to manage skills, agents, and commands across multiple AI coding assistants",
  "type": "module",
  "main": "./dist/cli/index.js",
  "bin": {
    "agent-manager": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest",
    "test:unit": "vitest --run --testNamePattern='unit'",
    "test:integration": "vitest --run --testNamePattern='integration'",
    "lint": "oxlint --import --jsx --jsx-a11y --typescript",
    "format": "oxfmt --write src/",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ai",
    "agent",
    "skill",
    "claude",
    "cursor",
    "gemini",
    "mcp",
    "copilot",
    "codex",
    "unjs"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "citty": "^0.1.6",
    "c12": "^3.3.3",
    "consola": "^3.4.2",
    "pathe": "^2.0.3",
    "execa": "^9.5.2",
    "ofetch": "^1.4.1",
    "destr": "^2.0.3",
    "ufo": "^1.5.4",
    "mlly": "^1.7.3",
    "std-env": "^3.8.0",
    "fs-extra": "^11.2.0",
    "simple-git": "^3.27.0",
    "zod": "^3.24.2",
    "js-yaml": "^4.1.0",
    "oxlint": "^1.41.0",
    "oxfmt": "^0.26.0",
    "tsdown": "^0.10.2"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.13.5",
    "typescript": "^5.7.3",
    "vitest": "^3.0.6",
    "@oxfmt/linux-x64-gnu": "^0.26.0",
    "@oxlint-tsgolint/linux-x64": "^0.11.1",
    "tsdown": "^0.10.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
